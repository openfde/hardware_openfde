cc_library_shared {
    name: "hwcomposer.x11",
    relative_install_path: "hw",
    vendor: true,
    shared_libs: [
        "liblog",
        "libutils",
        "libcutils",
        "libhardware",
        "libhidlbase",
        "libhidltransport",
        "libhwbinder",
        "libsync",
        "libui",
        "libdrm",
        "libEGL",
        "libGLESv2",
        "libX11",
        "libX11-xcb",
        "libXrender",
        "libxcb",
        "libxcb-xinput",
        "libxcb-randr",
        "libxcb-imdkit",
        "libxcb-util",
        "libxcb-dri3",
        "libxcb-shape",
        "vendor.openfde.display@1.0",
        "vendor.openfde.display@1.1",
        "vendor.openfde.task@1.0",
        "vendor.openfde.window@1.0",
        "vendor.openfde.window@1.1",
        "vendor.openfde.window@1.2",
    ],
    static_libs: [
        "libwayland_client_static",
        "libffi",
        "libwayland_extension_client_protocols",
        "libxkbcommon",
    ],
    srcs: [
        "extension.cpp",
        "hwcomposer.cpp",
        "x11-hwc.cpp",
        "WaydroidWindow.cpp",
        "egl-tools.cpp",
    ],
    header_libs: [
        "libsystem_headers",
        "minigbm_headers",
    ],
    include_dirs: [
        "system/core",
        "system/core/libsync",
        "system/core/libsync/include",
        "device/generic/goldfish-opengl/shared/gralloc_cb/include",
        "device/generic/goldfish-opengl/shared/qemupipe/include",
        "device/generic/goldfish-opengl/shared/qemupipe/include-types",
    ],

    local_include_dirs: [
        "include"
    ],

    arch : {
        arm: {
            enabled: false,
        },
        x86 : {
            enabled : false,
        },
        x86_64 : {
            enabled : false,
        },
        arm64: {
            enabled: true,
        },
    },

    cflags: [
        "-DLOG_TAG=\"hwcomposer\"",
        "-Wall",
        "-Werror",
        "-Wno-writable-strings",
    ],
    generated_sources: ["wayland_android_client_protocol_sources"],
    generated_headers: ["wayland_android_client_protocol_headers"],
}

