// hw/<OVERLAY_HARDWARE_MODULE_ID>.<ro.product.board>.so
cc_prebuilt_library_shared {
    name: "libXrender",
    arch: {
        arm: {
            enabled: false,
        },
        x86 : {
            enabled : false,
        },
        x86_64 : {
            enabled : false,
        },
        arm64: {
            srcs: ["lib/libXrender.so"],
        },
    },

    shared_libs: [
        "libX11",
        "libxcb",
        "libandroid-support",
        "libdl",
    ],
    proprietary : true,
    vendor: false,
    visibility: ["//hardware/openfde/hwcomposerx11"],
}
