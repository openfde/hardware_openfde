package vendor.openfde.task@1.0;

interface IOpenfdeTask {
    setFocusedTask(uint32_t taskID);
    removeTask(uint32_t taskID);
    removeAllVisibleRecentTasks();
    getAppName(string packageName) generates (string name);
    commitText(string text);
    sendKeyEvent(int32_t action, int32_t code);
};
